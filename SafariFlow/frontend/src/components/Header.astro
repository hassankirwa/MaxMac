---
interface Props {
  variant?: 'transparent' | 'solid';
}

const { variant = 'solid' } = Astro.props;

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Packages', href: '/packages' },
  { label: 'Destinations', href: '/destinations' },
  { label: 'Experiences', href: '/experiences' },
  { label: 'Trip Types', href: '/trip-types' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header
  class:list={[
    'relative z-30 w-full',
    variant === 'transparent' ? 'absolute inset-x-0 top-0 z-30' : 'bg-white border-b border-border-subtle',
  ]}
>
  <div class="mx-auto flex w-full max-w-[1440px] items-center justify-between gap-6 px-5 lg:px-8 py-5 lg:py-6">
    <a href="/" class="flex flex-shrink-0 items-center gap-2.5">
      <span class="flex h-9 w-9 lg:h-[38px] lg:w-[38px] items-center justify-center rounded-[10px] bg-savannah-gold">
        <svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="#1F5E3B" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 20h18M5 20l3-9 4 5 3-8 4 12"/></svg>
      </span>
      <span
        class:list={[
          'text-[19px] font-extrabold tracking-tight',
          variant === 'transparent' ? 'text-white' : 'text-text-primary',
        ]}
      >
        MAXMAC<span class="text-savannah-gold"> SAFARIS</span>
      </span>
    </a>

    <nav class="hidden lg:flex items-center gap-6 xl:gap-8 text-[15px] font-medium">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'transition-colors',
            isActive(link.href)
              ? variant === 'transparent' ? 'text-white font-semibold' : 'text-safari-green font-semibold'
              : variant === 'transparent' ? 'text-white/90 hover:text-white' : 'text-text-secondary hover:text-safari-green',
          ]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="hidden lg:flex items-center gap-2.5 xl:gap-3 flex-shrink-0">
      <label class="sr-only" for="sf-currency-desktop">Currency</label>
      <select
        id="sf-currency-desktop"
        data-currency-select
        aria-label="Currency"
        class:list={[
          'h-10 flex-shrink-0 cursor-pointer rounded-btn border bg-transparent px-2.5 text-sm font-semibold transition-colors focus:outline-none focus:ring-2 focus:ring-savannah-gold/40',
          variant === 'transparent'
            ? 'border-white/30 text-white hover:bg-white/10 [&>option]:text-text-primary'
            : 'border-border-muted text-text-primary hover:border-safari-green',
        ]}
      ></select>
      <a
        href="tel:+254712000000"
        class:list={[
          'hidden xl:flex items-center gap-1.5 whitespace-nowrap text-sm font-medium flex-shrink-0',
          variant === 'transparent' ? 'text-white' : 'text-text-secondary',
        ]}
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3-8.6A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .4 1.9.7 2.8a2 2 0 0 1-.5 2.1L8.1 9.9a16 16 0 0 0 6 6l1.3-1.2a2 2 0 0 1 2.1-.5c.9.3 1.8.6 2.8.7a2 2 0 0 1 1.7 2z"/></svg>
        +254 712 000 000
      </a>
      <a
        href="/cart"
        data-cart-indicator
        aria-label="Your trip"
        title="Your trip"
        class:list={[
          'relative hidden h-10 w-10 flex-shrink-0 items-center justify-center rounded-btn border transition-colors',
          variant === 'transparent'
            ? 'border-white/30 text-white hover:bg-white/10'
            : 'border-border-muted text-text-primary hover:border-safari-green',
        ]}
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        <span
          data-cart-indicator-badge
          class="absolute -right-1.5 -top-1.5 flex h-5 min-w-[20px] items-center justify-center rounded-full bg-savannah-gold px-1 text-[11px] font-bold text-text-primary"
        ></span>
      </a>
      <a
        href="/packages"
        class:list={[
          'flex-shrink-0 whitespace-nowrap rounded-btn px-[22px] py-[11px] text-sm font-bold transition-transform active:scale-[0.98]',
          variant === 'transparent'
            ? 'bg-savannah-gold text-text-primary shadow-[0_8px_20px_-8px_rgba(212,160,23,0.7)]'
            : 'bg-safari-green text-white',
        ]}
      >
        Book Now
      </a>
    </div>

    <button
      type="button"
      data-menu-toggle
      aria-label="Open menu"
      aria-expanded="false"
      class:list={[
        'flex lg:hidden h-10 w-10 items-center justify-center rounded-[11px] border transition-colors',
        variant === 'transparent'
          ? 'bg-white/15 border-white/25 text-white'
          : 'bg-warm-sand border-border-muted text-text-primary',
      ]}
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
    </button>
  </div>
</header>

<!-- Mobile menu overlay -->
<div
  data-menu-overlay
  class="fixed inset-0 z-50 -translate-y-3 bg-gradient-to-br from-safari-green to-ink opacity-0 pointer-events-none transition-all duration-300 lg:hidden"
>
  <div class="flex items-center justify-between px-6 pt-12 pb-6">
    <a href="/" class="flex items-center gap-2.5 text-white">
      <span class="flex h-8 w-8 items-center justify-center rounded-[9px] bg-savannah-gold">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1F5E3B" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 20h18M5 20l3-9 4 5 3-8 4 12"/></svg>
      </span>
      <span class="text-base font-extrabold">MAXMAC SAFARIS</span>
    </a>
    <button
      type="button"
      data-menu-close
      aria-label="Close menu"
      class="flex h-10 w-10 items-center justify-center rounded-[11px] bg-white/10 text-white"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18M6 6l12 12"/></svg>
    </button>
  </div>

  <nav class="flex flex-col px-6 mt-6">
    {navLinks.map((link) => (
      <a
        href={link.href}
        class="flex items-center justify-between border-b border-white/10 py-4 text-[26px] font-semibold text-white"
      >
        {link.label}
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.4)" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      </a>
    ))}
  </nav>

  <div class="flex flex-col gap-3 px-6 mt-8">
    <a
      href="/cart"
      data-cart-indicator
      class="hidden items-center justify-center gap-2 rounded-btn border border-white/25 py-3.5 text-center text-[15px] font-semibold text-white"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
      <span data-cart-indicator-label>Your trip</span>
    </a>
    <a href="/packages" class="block rounded-btn bg-savannah-gold py-4 text-center text-base font-bold text-text-primary">
      Book now
    </a>
    <label class="sr-only" for="sf-currency-mobile">Currency</label>
    <select
      id="sf-currency-mobile"
      data-currency-select
      aria-label="Currency"
      class="w-full cursor-pointer rounded-btn border border-white/25 bg-transparent px-4 py-3.5 text-[15px] font-semibold text-white focus:outline-none [&>option]:text-text-primary"
    ></select>
    <a href="tel:+254712000000" class="flex items-center justify-center gap-2 text-sm text-white/70">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3-8.6A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .4 1.9.7 2.8a2 2 0 0 1-.5 2.1L8.1 9.9a16 16 0 0 0 6 6l1.3-1.2a2 2 0 0 1 2.1-.5c.9.3 1.8.6 2.8.7a2 2 0 0 1 1.7 2z"/></svg>
      +254 712 000 000
    </a>
  </div>
</div>

<script>
  function initMenu() {
    const toggle = document.querySelector('[data-menu-toggle]');
    const close = document.querySelector('[data-menu-close]');
    const overlay = document.querySelector('[data-menu-overlay]');
    if (!toggle || !overlay) return;

    const open = () => {
      overlay.classList.remove('opacity-0', 'pointer-events-none', '-translate-y-3');
      toggle.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    };
    const shut = () => {
      overlay.classList.add('opacity-0', 'pointer-events-none', '-translate-y-3');
      toggle.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    };

    toggle.addEventListener('click', open);
    close?.addEventListener('click', shut);
    overlay.querySelectorAll('a').forEach((a) => a.addEventListener('click', shut));
  }

  initMenu();
  document.addEventListener('astro:after-swap', initMenu);
</script>

<script>
  import { getCartSelection, travelerCount, CART_EVENT, type CartSelection } from '../lib/cart';
  import { formatMoney } from '../lib/money';

  function renderCartIndicator() {
    const selection = getCartSelection();
    document.querySelectorAll('[data-cart-indicator]').forEach((el) => {
      const label = el.querySelector('[data-cart-indicator-label]');
      const badge = el.querySelector('[data-cart-indicator-badge]');
      if (selection) {
        const pax = travelerCount(selection);
        if (label) {
          label.textContent = `${pax} traveler${pax === 1 ? '' : 's'} · ${formatMoney(selection.total, selection.currency)}`;
        }
        if (badge) {
          badge.textContent = String(pax);
        }
        el.classList.remove('hidden');
        el.classList.add('flex');
      } else {
        el.classList.add('hidden');
        el.classList.remove('flex');
      }
    });
  }

  renderCartIndicator();
  document.addEventListener('astro:after-swap', renderCartIndicator);
  window.addEventListener(CART_EVENT, renderCartIndicator as EventListener);
  window.addEventListener('sf-currency-changed', renderCartIndicator);
  window.addEventListener('storage', renderCartIndicator);
</script>
