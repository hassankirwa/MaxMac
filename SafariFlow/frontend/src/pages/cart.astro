---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Your Trip">
  <Header variant="solid" />

  <div class="container-page py-12 lg:py-16">
    <h1 class="text-3xl lg:text-4xl font-bold tracking-tight text-text-primary">Your trip</h1>
    <p class="mt-2 text-[15px] text-text-secondary">Review your selection before checkout.</p>

    <div class="mt-8 max-w-2xl">
      <!-- empty state -->
      <div data-cart-empty class="hidden rounded-card bg-white p-10 text-center shadow-[0_14px_36px_-30px_rgba(31,50,40,0.5)]">
        <div class="text-lg font-semibold text-text-primary">No trip selected yet</div>
        <p class="mt-2 text-sm text-text-secondary">Browse our safari packages and pick one to get started.</p>
        <a href="/packages" class="mt-6 inline-block rounded-btn bg-safari-green px-6 py-3 text-sm font-bold text-white">Browse packages</a>
      </div>

      <!-- selection summary -->
      <div data-cart-summary class="hidden rounded-card bg-white p-6 lg:p-8 shadow-[0_14px_36px_-30px_rgba(31,50,40,0.5)]">
        <div class="flex items-start justify-between gap-4">
          <div>
            <div data-cart-trip-name class="text-xl font-bold text-text-primary"></div>
            <div data-cart-package-name class="mt-1 text-sm font-semibold text-savannah-gold"></div>
          </div>
          <a data-cart-edit-link href="#" class="whitespace-nowrap text-sm font-semibold text-safari-green hover:underline">Edit selection</a>
        </div>

        <div class="mt-5 flex items-center gap-2 border-t border-border-subtle pt-5 text-sm text-text-secondary">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#1F5E3B" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
          <span data-cart-date></span>
        </div>

        <div data-cart-travelers class="mt-4 flex flex-col gap-2"></div>

        <div class="mt-5 flex items-center justify-between border-t border-border-subtle pt-5">
          <span class="text-base font-semibold text-text-primary">Total</span>
          <span data-cart-total class="text-2xl font-bold text-safari-green"></span>
        </div>
        <p data-cart-partial-note class="mt-2 hidden text-xs font-medium text-savannah-gold"></p>
        <p data-sf-currency-note class="mt-2 hidden text-xs text-text-secondary/80"></p>

        <div class="mt-6 flex flex-col gap-3 sm:flex-row">
          <a data-cart-checkout-link href="/checkout" class="flex-1 rounded-btn bg-safari-green py-3.5 text-center text-[15px] font-bold text-white">Proceed to checkout</a>
          <button type="button" data-cart-clear class="rounded-btn border border-border-muted px-6 py-3.5 text-sm font-semibold text-text-secondary">Clear selection</button>
        </div>
      </div>
    </div>
  </div>

  <Footer />
</Layout>

<script>
  import { getCartSelection, clearCartSelection, travelerCount, CART_EVENT } from '../lib/cart';
  import { formatMoney } from '../lib/money';

  function render() {
    const selection = getCartSelection();
    const empty = document.querySelector('[data-cart-empty]');
    const summary = document.querySelector('[data-cart-summary]');

    if (!selection) {
      empty?.classList.remove('hidden');
      summary?.classList.add('hidden');
      return;
    }

    empty?.classList.add('hidden');
    summary?.classList.remove('hidden');

    const tripNameEl = document.querySelector('[data-cart-trip-name]');
    const packageNameEl = document.querySelector('[data-cart-package-name]');
    const editLink = document.querySelector('[data-cart-edit-link]');
    const dateEl = document.querySelector('[data-cart-date]');
    const travelersEl = document.querySelector('[data-cart-travelers]');
    const totalEl = document.querySelector('[data-cart-total]');
    const partialNoteEl = document.querySelector('[data-cart-partial-note]');

    if (tripNameEl) tripNameEl.textContent = selection.tripName;
    if (packageNameEl) packageNameEl.textContent = selection.packageName;
    if (editLink) editLink.setAttribute('href', `/packages/${selection.tripSlug}`);

    if (dateEl) {
      const d = selection.tripDate ? new Date(selection.tripDate) : null;
      dateEl.textContent = d
        ? d.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' })
        : 'No date selected';
    }

    if (travelersEl) {
      travelersEl.innerHTML = selection.travelers
        .map(
          (t) => `
          <div class="flex items-center justify-between text-sm">
            <span class="text-text-secondary">${t.label} &times; ${t.count}</span>
            <span class="font-medium text-text-primary">${formatMoney(t.count * t.pricePerPerson, selection.currency)}</span>
          </div>`
        )
        .join('');
    }

    if (totalEl) totalEl.textContent = formatMoney(selection.total, selection.currency);

    if (partialNoteEl) {
      if (selection.partialPayment?.available) {
        partialNoteEl.textContent =
          selection.partialPayment.type === 'amount'
            ? `Deposit option available: ${formatMoney(Number(selection.partialPayment.amount), selection.currency)} now, remainder before departure.`
            : 'A deposit option is available for this trip.';
        partialNoteEl.classList.remove('hidden');
      } else {
        partialNoteEl.classList.add('hidden');
      }
    }

    const pax = travelerCount(selection);
    document.title = `Your trip (${pax} traveler${pax === 1 ? '' : 's'}) · MaxMac Safaris`;
  }

  function initCartPage() {
    render();
    document.querySelector('[data-cart-clear]')?.addEventListener('click', () => {
      clearCartSelection();
      render();
    });
  }

  initCartPage();
  document.addEventListener('astro:after-swap', initCartPage);
  window.addEventListener(CART_EVENT, render);
  window.addEventListener('sf-currency-changed', render);
</script>
