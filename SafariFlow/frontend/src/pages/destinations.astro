---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CtaBand from '../components/CtaBand.astro';
import { getDestinations, type TaxonomyTerm } from '../lib/wte';
import { destOptions } from '../data/packages';

// Live from WordPress: the WTE "destination" taxonomy + real trip counts. Falls back to the
// static destOptions list (counts hidden) if WP is unreachable, so the page always renders.
const live = await getDestinations();
const destinations: TaxonomyTerm[] = live.length
  ? live
  : destOptions.map((name) => ({ name, slug: name.toLowerCase().replace(/[^a-z0-9]+/g, '-'), count: 0, parent: 0 }));

// Curated presentation (imagery/copy/country) keyed by destination name, merged onto live data.
// Unknown destinations rotate through a neutral fallback so newly-added WTE terms still render.
type Presentation = { gradient: [string, string]; blurb: string; country: string };
const PRESENTATION: Record<string, Presentation> = {
  Tanzania: { gradient: ['#c98a3c', '#7a4a1e'], blurb: 'The classic circuit — Serengeti plains, Ngorongoro Crater and the Great Migration.', country: 'Tanzania' },
  Kenya: { gradient: ['#c98a3c', '#6e4a22'], blurb: 'Big-cat country — the Masai Mara, elephant herds of Amboseli and Rift Valley lakes.', country: 'Kenya' },
  'Kenyan Coast': { gradient: ['#3fa9c9', '#1c6f86'], blurb: 'Powder-white sand, coral reefs and Swahili towns from Diani to Lamu.', country: 'Kenya' },
  Zanzibar: { gradient: ['#4a9d7a', '#256149'], blurb: 'Spice-island history in Stone Town and turquoise Indian Ocean shallows.', country: 'Tanzania' },
};
const FALLBACK_GRADIENTS: [string, string][] = [
  ['#c98a3c', '#7a4a1e'], ['#3fa9c9', '#1c6f86'], ['#5b7fa6', '#2c4a63'], ['#4a9d7a', '#256149'],
];
const presFor = (name: string, i: number): Presentation =>
  PRESENTATION[name] ?? { gradient: FALLBACK_GRADIENTS[i % FALLBACK_GRADIENTS.length], blurb: 'Explore handcrafted safaris across this region.', country: 'East Africa' };

const cards = destinations.map((d, i) => ({ ...d, ...presFor(d.name, i) }));
---

<Layout title="Destinations">
  <Header variant="solid" />

  <!-- hero banner -->
  <div class="relative h-[280px] overflow-hidden sm:h-[320px] lg:h-[340px]" style="background:linear-gradient(150deg,#c98a3c,#7a4a1e);">
    <div class="absolute inset-0 bg-gradient-to-b from-[rgba(13,26,18,0.5)] via-[rgba(13,26,18,0.3)] to-[rgba(13,26,18,0.6)]"></div>
    <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(80% 120% at 88% 10%, rgba(212,160,23,0.25), transparent 55%);"></div>
    <div class="container-page relative flex h-full flex-col justify-center">
      <div class="flex items-center gap-2 text-[13px] font-medium text-white/75">
        <a href="/" class="hover:text-white">Home</a> <span>/</span> <span class="text-savannah-gold">Destinations</span>
      </div>
      <h1 class="mt-3 max-w-[640px] text-[32px] leading-[1.1] sm:text-4xl lg:text-[52px] lg:leading-[1.05] font-bold tracking-tight text-white">
        Where will Africa take you?
      </h1>
      <p class="mt-2.5 max-w-[560px] text-[15px] sm:text-lg text-white/85">
        From the migration plains of the Serengeti to the coral lanes of Lamu — explore every corner we call home.
      </p>
    </div>
  </div>

  <!-- destination grid -->
  <div class="container-page pt-10 pb-4">
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3 lg:gap-6">
      {cards.map((d) => (
        <a
          href={`/packages?dest=${encodeURIComponent(d.name)}`}
          class="group block overflow-hidden rounded-card bg-white shadow-[0_18px_40px_-30px_rgba(31,50,40,0.4)] transition-shadow hover:shadow-[0_22px_48px_-24px_rgba(31,50,40,0.5)]"
        >
          <div class="relative h-[200px] sm:h-[220px]" style={`background:linear-gradient(150deg, ${d.gradient[0]}, ${d.gradient[1]});`}>
            <div class="absolute inset-0" style="background:linear-gradient(0deg, rgba(13,26,18,.62), rgba(13,26,18,.05) 55%);"></div>
            {d.count > 0 && (
              <div class="absolute right-3.5 top-3.5 rounded-lg bg-white/90 px-2.5 py-1.5 text-xs font-bold text-safari-green">{d.count} {d.count === 1 ? 'trip' : 'trips'}</div>
            )}
            <div class="absolute bottom-4 left-4 text-white">
              <div class="text-xl sm:text-2xl font-bold tracking-tight">{d.name}</div>
              <div class="mt-1 flex items-center gap-1.5 text-[13px] text-white/82">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/></svg>
                {d.country}
              </div>
            </div>
          </div>
          <div class="p-4 sm:p-5">
            <p class="min-h-[44px] text-sm leading-relaxed text-text-secondary">{d.blurb}</p>
            <div class="mt-3 flex items-center gap-1.5 text-sm font-bold text-safari-green">
              Explore {d.name}
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>

  <CtaBand
    heading="Not sure where to start? We'll help you choose."
    text="Tell us your dates and dreams — we'll match you to the perfect region."
    buttons={[{ label: 'Talk to an expert', href: '/contact', variant: 'gold' }]}
  />

  <Footer />
</Layout>
