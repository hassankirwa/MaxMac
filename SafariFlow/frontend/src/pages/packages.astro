---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { packages as staticPackages, destOptions, expOptions, durOptions, sortOptions } from '../data/packages';
import { getTrips } from '../lib/wte';
import { formatMoney } from '../lib/money';

// Source the catalog from WordPress (headless); fall back to bundled data if WP is unreachable.
const wpPackages = await getTrips();
const allPackages = wpPackages.length ? wpPackages : staticPackages;

// The whole catalog shares one site-wide currency (WTE's currency_code setting) — derive the
// budget slider's bounds from real data instead of a hardcoded USD-scale range, since KES (or
// any other currency) prices land on a very different order of magnitude.
const catalogCurrency = allPackages[0]?.currency || 'USD';
const priceValues = allPackages.map((p) => p.priceN);
const catalogMinPrice = Math.min(...priceValues);
const catalogMaxPrice = Math.max(...priceValues);
const budgetStep = Math.max(1, Math.round((catalogMaxPrice - catalogMinPrice) / 20 / 10) * 10) || 1;

const destCounts: Record<string, number> = {};
destOptions.forEach((d) => (destCounts[d] = allPackages.filter((p) => p.dest === d).length));
---

<Layout title="Safari Packages">
  <Header variant="solid" />

  <!-- page banner -->
  <div class="relative overflow-hidden bg-gradient-to-r from-safari-green to-[#2b4a34] px-5 py-11 sm:px-10 lg:px-14 lg:py-11">
    <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(80% 140% at 88% 10%, rgba(212,160,23,0.28), transparent 55%);"></div>
    <div class="container-page !px-0 relative">
      <div class="flex items-center gap-2 text-[13px] font-medium text-white/70">
        <a href="/" class="hover:text-white">Home</a> <span>/</span> <span class="text-savannah-gold">Packages</span>
      </div>
      <h1 class="mt-3 text-3xl sm:text-4xl lg:text-[44px] font-bold tracking-tight text-white">Safari packages</h1>
      <p class="mt-2 max-w-[560px] text-[15px] sm:text-[17px] text-white/80">
        <span data-result-count>{allPackages.length}</span> handcrafted journeys across East Africa &amp; the Swahili coast. Filter to find your perfect trip.
      </p>
    </div>
  </div>

  <!-- search summary (shown when arriving from the homepage search) -->
  <div data-search-summary class="hidden container-page pt-5">
    <div class="flex flex-wrap items-center gap-2 rounded-xl bg-white px-4 py-3 text-sm text-text-secondary shadow-[0_8px_24px_-22px_rgba(31,50,40,0.5)]">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#1F5E3B" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      <span data-search-summary-text class="font-medium text-text-primary"></span>
      <button type="button" data-clear-search-summary class="ml-auto text-xs font-semibold text-safari-green">Clear search</button>
    </div>
  </div>

  <!-- mobile quick exp chips + filter/sort bar -->
  <div class="lg:hidden">
    <div class="scroll-x-touch flex gap-2 overflow-x-auto px-5 pb-2 pt-4" data-mobile-exp-chips></div>
    <div class="flex gap-2.5 px-5 pb-4">
      <button type="button" data-open-sheet class="flex flex-1 items-center justify-center gap-2 rounded-xl border border-border-muted bg-white px-3 py-3 text-sm font-semibold text-text-primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1F5E3B" stroke-width="2"><path d="M4 6h16M7 12h10M10 18h4"/></svg>
        Filters
        <span data-active-badge class="hidden items-center justify-center rounded-full bg-safari-green px-1.5 text-xs font-bold text-white"></span>
      </button>
      <button type="button" data-cycle-sort class="flex flex-1 items-center justify-center gap-2 rounded-xl border border-border-muted bg-white px-3 py-3 text-sm font-semibold text-text-primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1F5E3B" stroke-width="2"><path d="M3 6h13M3 12h9M3 18h5M18 8l3-3 3 3M21 5v14"/></svg>
        <span data-sort-label>Recommended</span>
      </button>
    </div>
  </div>

  <div class="container-page flex flex-col gap-9 pb-20 pt-4 lg:flex-row lg:items-start lg:pt-10">
    <!-- SIDEBAR (desktop static / mobile bottom sheet) -->
    <aside
      data-filter-panel
      class="fixed inset-x-0 bottom-0 z-40 max-h-[85vh] translate-y-full overflow-y-auto rounded-t-modal bg-white p-6 shadow-[0_-20px_50px_-20px_rgba(13,26,18,0.4)] transition-transform duration-300 ease-out lg:static lg:z-auto lg:w-[280px] lg:flex-shrink-0 lg:translate-y-0 lg:rounded-card lg:p-6 lg:shadow-[0_14px_36px_-30px_rgba(31,50,40,0.5)]"
    >
      <div class="mb-1 flex items-center justify-between">
        <span class="hidden h-1 lg:hidden"></span>
      </div>
      <div class="mb-4 flex justify-center lg:hidden">
        <div class="h-[5px] w-10 rounded-full bg-border-muted"></div>
      </div>
      <div class="mb-1 flex items-center justify-between">
        <div class="text-lg font-bold text-text-primary">Filters</div>
        <button type="button" data-clear-filters class="text-sm font-semibold text-safari-green">Clear all</button>
      </div>

      <div class="mt-4 border-t border-border-subtle pt-5">
        <div class="mb-3.5 text-sm font-bold text-text-primary">Destination</div>
        <div data-dest-filters class="flex flex-col"></div>
      </div>

      <div class="mt-5 border-t border-border-subtle pt-5">
        <div class="mb-3.5 text-sm font-bold text-text-primary">Experience</div>
        <div data-exp-filters class="flex flex-col lg:flex lg:flex-col"></div>
      </div>

      <div class="mt-5 border-t border-border-subtle pt-5">
        <div class="mb-4 flex items-center justify-between">
          <div class="text-sm font-bold text-text-primary">Max budget</div>
          <div data-budget-label class="text-sm font-bold text-safari-green">{formatMoney(catalogMaxPrice, catalogCurrency)}+</div>
        </div>
        <input type="range" min={catalogMinPrice} max={catalogMaxPrice} step={budgetStep} value={catalogMaxPrice} data-budget-input class="w-full" />
        <div class="mt-2 flex justify-between text-xs text-text-secondary/80"><span data-sf-amount={catalogMinPrice} data-sf-currency={catalogCurrency}>{formatMoney(catalogMinPrice, catalogCurrency)}</span><span data-sf-amount={catalogMaxPrice} data-sf-currency={catalogCurrency} data-sf-suffix="+">{formatMoney(catalogMaxPrice, catalogCurrency)}+</span></div>
      </div>

      <div class="mt-5 border-t border-border-subtle pt-5">
        <div class="mb-3.5 text-sm font-bold text-text-primary">Duration</div>
        <div data-dur-filters class="flex flex-wrap gap-2"></div>
      </div>

      <div class="mt-6 border-t border-border-subtle pt-5 lg:hidden">
        <button type="button" data-close-sheet class="w-full rounded-btn bg-safari-green py-[15px] text-center text-base font-bold text-white">
          Show <span data-sheet-count>{allPackages.length}</span> packages
        </button>
      </div>
    </aside>
    <div data-sheet-scrim class="fixed inset-0 z-30 bg-[rgba(13,26,18,0.4)] opacity-0 pointer-events-none transition-opacity duration-250 lg:hidden"></div>

    <!-- RESULTS -->
    <div class="min-w-0 flex-1">
      <div class="mb-5 hidden items-center justify-between lg:flex">
        <div class="text-[15px] text-text-secondary"><span data-result-count-2 class="font-bold text-text-primary">{allPackages.length}</span> packages found</div>
        <div class="flex items-center gap-2.5">
          <span class="text-sm text-text-secondary/80">Sort by</span>
          <div data-sort-tabs class="flex gap-1.5 rounded-xl bg-white p-1.5 shadow-[0_8px_24px_-22px_rgba(31,50,40,0.5)]"></div>
        </div>
      </div>

      <div data-results-grid class="grid grid-cols-1 gap-6 sm:grid-cols-2 xl:grid-cols-3"></div>
      <div data-empty-state class="hidden py-16 text-center text-text-secondary">
        <div class="text-lg font-semibold text-text-primary">No packages match your filters</div>
        <div class="mt-1.5 text-sm">Try widening your budget or clearing a filter.</div>
      </div>
    </div>
  </div>

  <Footer />
</Layout>

<script define:vars={{ allPackages, destOptions, expOptions, durOptions, sortOptions, destCounts, catalogCurrency, catalogMaxPrice }}>
  // define:vars scripts are always inlined by Astro (no bundling), so this can't import
  // src/lib/money.ts — small inline equivalent instead. When the currency runtime is ready
  // it converts base-currency amounts to the visitor's display currency (via window.__sfFormat).
  const formatMoney = (amount, currency) => {
    const w = window;
    if (w.__sfCurrency?.ready && w.__sfFormat && w.__sfCurrency.base === currency) {
      return w.__sfFormat(amount);
    }
    try {
      return new Intl.NumberFormat('en-US', { style: 'currency', currency, maximumFractionDigits: 0 }).format(amount);
    } catch {
      return `${currency} ${Math.round(amount).toLocaleString()}`;
    }
  };

  const state = { dest: [], exp: [], maxBudget: catalogMaxPrice, dur: 'Any', sort: 0, sheetOpen: false };

  // seed filters from ?exp=&dest=&checkin=&adults= when arriving from the homepage search
  const urlParams = new URLSearchParams(window.location.search);
  const urlExp = urlParams.get('exp');
  const urlDest = urlParams.get('dest');
  const urlCheckin = urlParams.get('checkin');
  const urlCheckout = urlParams.get('checkout');
  const urlAdults = urlParams.get('adults');
  const urlChildren = urlParams.get('children');
  const urlInfants = urlParams.get('infants');
  if (urlExp && expOptions.includes(urlExp)) state.exp.push(urlExp);
  if (urlDest && destOptions.includes(urlDest)) state.dest.push(urlDest);

  // Forward the party + preferred date onto each trip link so the booking widget on the
  // trip page pre-seeds its WTE traveler-category steppers from the homepage search.
  const forwardParams = new URLSearchParams();
  if (urlAdults) forwardParams.set('adults', urlAdults);
  if (urlChildren) forwardParams.set('children', urlChildren);
  if (urlInfants) forwardParams.set('infants', urlInfants);
  if (urlCheckin) forwardParams.set('date', urlCheckin);
  const paxQuery = forwardParams.toString() ? `?${forwardParams.toString()}` : '';

  function renderSearchSummary() {
    const box = document.querySelector('[data-search-summary]');
    const text = document.querySelector('[data-search-summary-text]');
    if (!box || !text) return;
    const parts = [];
    if (urlDest) parts.push(urlDest);
    if (urlExp) parts.push(urlExp);
    const fmt = (iso) => new Date(iso).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
    if (urlCheckin && urlCheckout) parts.push(`${fmt(urlCheckin)} – ${fmt(urlCheckout)}`);
    else if (urlCheckin) parts.push(`from ${fmt(urlCheckin)}`);
    const paxParts = [];
    if (urlAdults) paxParts.push(`${urlAdults} adult${urlAdults === '1' ? '' : 's'}`);
    if (urlChildren && urlChildren !== '0') paxParts.push(`${urlChildren} child${urlChildren === '1' ? '' : 'ren'}`);
    if (urlInfants && urlInfants !== '0') paxParts.push(`${urlInfants} infant${urlInfants === '1' ? '' : 's'}`);
    if (paxParts.length) parts.push(paxParts.join(', '));
    if (parts.length === 0) {
      box.classList.add('hidden');
      return;
    }
    text.textContent = `Showing results for: ${parts.join(' · ')}`;
    box.classList.remove('hidden');
  }
  document.querySelector('[data-clear-search-summary]')?.addEventListener('click', () => {
    window.location.href = '/packages';
  });
  renderSearchSummary();

  const checkBoxIcon = (on) =>
    `<div style="width:20px;height:20px;flex-shrink:0;border-radius:6px;display:flex;align-items:center;justify-content:center;transition:.15s;${
      on ? 'background:#1F5E3B;' : 'background:#fff;border:1.5px solid #D8D2C6;'
    }"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3.2"><path d="M20 6 9 17l-5-5"/></svg></div>`;

  function toggle(key, val) {
    const arr = state[key];
    const idx = arr.indexOf(val);
    if (idx === -1) arr.push(val);
    else arr.splice(idx, 1);
    render();
  }

  function inDuration(days) {
    if (state.dur === 'Any') return true;
    if (state.dur === '1-4 days') return days <= 4;
    if (state.dur === '5-6 days') return days >= 5 && days <= 6;
    if (state.dur === '7+ days') return days >= 7;
    return true;
  }

  const sorters = [
    () => 0,
    (a, b) => a.priceN - b.priceN,
    (a, b) => b.rating - a.rating,
    (a, b) => a.days - b.days,
  ];

  function cardHtml(p) {
    return `
      <a href="/packages/${p.slug}${paxQuery}" class="group block overflow-hidden rounded-card border border-black/[0.04] bg-white shadow-[0_18px_40px_-30px_rgba(31,50,40,0.4)] transition-shadow hover:shadow-[0_22px_48px_-24px_rgba(31,50,40,0.5)]">
        <div class="relative h-[190px]" style="background:linear-gradient(150deg, ${p.gradient[0]}, ${p.gradient[1]});">
          ${(p.imageCard || p.image) ? `<img src="${p.imageCard || p.image}" alt="${(p.imageAlt || p.name).replace(/"/g, '&quot;')}" loading="lazy" decoding="async" class="absolute inset-0 h-full w-full object-cover" />` : ''}
          <div class="absolute inset-0 bg-gradient-to-b from-white/5 to-[rgba(15,28,20,0.32)]"></div>
          <div class="absolute left-3 top-3 rounded-lg bg-white/92 px-2.5 py-1.5 text-xs font-bold text-safari-green">${p.tag}</div>
          <div class="absolute bottom-2.5 left-3 flex items-center gap-1.5 text-xs font-semibold text-white">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/></svg>
            ${p.region}
          </div>
        </div>
        <div class="p-5">
          <div class="flex items-center justify-between text-xs">
            <span class="flex items-center gap-1.5 font-medium text-text-secondary">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#666" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
              ${p.days} days
            </span>
            <span class="flex items-center gap-1 font-bold text-text-primary">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="#D4A017" stroke="#D4A017"><path d="m12 2 3 6.3 6.9 1-5 4.9 1.2 6.8L12 17.8 5.9 21l1.2-6.8-5-4.9 6.9-1z"/></svg>
              ${p.rating.toFixed(1)}
            </span>
          </div>
          <h3 class="mt-2.5 mb-1.5 text-lg font-bold leading-tight tracking-tight text-text-primary">${p.name}</h3>
          <p class="min-h-[39px] text-[13px] leading-relaxed text-text-secondary">${p.blurb}</p>
          <div class="mt-3 flex flex-wrap gap-1.5">
            ${p.chips.map((c) => `<span class="rounded-md bg-[#F3F6F2] px-2.5 py-1 text-[11px] font-semibold text-safari-green">${c}</span>`).join('')}
          </div>
          <div class="mt-4 flex items-end justify-between gap-3 border-t border-border-subtle pt-4">
            <div class="min-w-0"><span class="text-[11px] text-text-secondary/80">from</span><div class="text-xl font-bold leading-tight text-safari-green">${formatMoney(p.priceN, p.currency || catalogCurrency)}<span class="text-xs font-medium text-text-secondary/80">/pp</span></div></div>
            <span class="inline-block flex-shrink-0 whitespace-nowrap rounded-[11px] bg-safari-green px-4 py-2.5 text-[13px] font-bold text-white transition-transform group-hover:brightness-105 group-active:scale-[0.98]">View trip</span>
          </div>
        </div>
      </a>`;
  }

  function render() {
    let filtered = allPackages.filter(
      (p) =>
        (state.dest.length === 0 || state.dest.includes(p.dest)) &&
        (state.exp.length === 0 || p.exps.some((e) => state.exp.includes(e))) &&
        p.priceN <= state.maxBudget &&
        inDuration(p.days)
    );
    filtered = [...filtered].sort(sorters[state.sort]);

    document.querySelectorAll('[data-result-count],[data-result-count-2],[data-sheet-count]').forEach((el) => {
      el.textContent = String(filtered.length);
    });

    const grid = document.querySelector('[data-results-grid]');
    const empty = document.querySelector('[data-empty-state]');
    if (grid) grid.innerHTML = filtered.map(cardHtml).join('');
    empty?.classList.toggle('hidden', filtered.length !== 0);
    grid?.classList.toggle('hidden', filtered.length === 0);

    // destination filters
    const destWrap = document.querySelector('[data-dest-filters]');
    if (destWrap) {
      destWrap.innerHTML = destOptions
        .map(
          (d) => `
          <div data-dest-item="${d}" class="flex cursor-pointer items-center gap-2.5 py-1.5">
            ${checkBoxIcon(state.dest.includes(d))}
            <span class="flex-1 text-sm font-medium text-text-primary">${d}</span>
            <span class="text-xs text-text-secondary/70">${destCounts[d]}</span>
          </div>`
        )
        .join('');
      destWrap.querySelectorAll('[data-dest-item]').forEach((el) => {
        el.addEventListener('click', () => toggle('dest', el.getAttribute('data-dest-item')));
      });
    }

    // experience filters (desktop checklist)
    const expWrap = document.querySelector('[data-exp-filters]');
    if (expWrap) {
      expWrap.innerHTML = expOptions
        .map(
          (e) => `
          <div data-exp-item="${e}" class="flex cursor-pointer items-center gap-2.5 py-1.5">
            ${checkBoxIcon(state.exp.includes(e))}
            <span class="text-sm font-medium text-text-primary">${e}</span>
          </div>`
        )
        .join('');
      expWrap.querySelectorAll('[data-exp-item]').forEach((el) => {
        el.addEventListener('click', () => toggle('exp', el.getAttribute('data-exp-item')));
      });
    }

    // mobile quick exp chips
    const mChips = document.querySelector('[data-mobile-exp-chips]');
    if (mChips) {
      const chipStyle = (on) =>
        `cursor:pointer;white-space:nowrap;font-size:13px;font-weight:600;padding:9px 14px;border-radius:100px;transition:.15s;${
          on ? 'background:#1F5E3B;color:#fff;' : 'background:#F3F1EB;color:#555;'
        }`;
      mChips.innerHTML = expOptions
        .map((e) => `<div data-mchip="${e}" style="${chipStyle(state.exp.includes(e))}">${e}</div>`)
        .join('');
      mChips.querySelectorAll('[data-mchip]').forEach((el) => {
        el.addEventListener('click', () => toggle('exp', el.getAttribute('data-mchip')));
      });
    }

    // duration pills
    const durWrap = document.querySelector('[data-dur-filters]');
    if (durWrap) {
      durWrap.innerHTML = durOptions
        .map(
          (d) =>
            `<div data-dur-item="${d}" class="cursor-pointer rounded-lg px-3 py-2 text-[13px] font-semibold transition-colors ${
              state.dur === d ? 'bg-safari-green text-white' : 'bg-[#F3F1EB] text-[#555]'
            }">${d}</div>`
        )
        .join('');
      durWrap.querySelectorAll('[data-dur-item]').forEach((el) => {
        el.addEventListener('click', () => {
          state.dur = el.getAttribute('data-dur-item');
          render();
        });
      });
    }

    // sort tabs (desktop)
    const sortWrap = document.querySelector('[data-sort-tabs]');
    if (sortWrap) {
      sortWrap.innerHTML = sortOptions
        .map(
          (label, i) =>
            `<div data-sort-item="${i}" class="cursor-pointer rounded-lg px-3.5 py-2 text-[13px] font-semibold transition-colors ${
              state.sort === i ? 'bg-safari-green text-white' : 'text-[#777]'
            }">${label}</div>`
        )
        .join('');
      sortWrap.querySelectorAll('[data-sort-item]').forEach((el) => {
        el.addEventListener('click', () => {
          state.sort = Number(el.getAttribute('data-sort-item'));
          render();
        });
      });
    }

    // mobile sort label + budget label + active badge
    const sortLabelEl = document.querySelector('[data-sort-label]');
    if (sortLabelEl) sortLabelEl.textContent = sortOptions[state.sort];

    const budgetLabelEl = document.querySelectorAll('[data-budget-label]');
    const budgetText = state.maxBudget >= catalogMaxPrice ? `${formatMoney(catalogMaxPrice, catalogCurrency)}+` : formatMoney(state.maxBudget, catalogCurrency);
    budgetLabelEl.forEach((el) => (el.textContent = budgetText));

    const activeCount = state.dest.length + state.exp.length;
    const badge = document.querySelector('[data-active-badge]');
    if (badge) {
      badge.textContent = String(activeCount);
      badge.classList.toggle('hidden', activeCount === 0);
      badge.classList.toggle('inline-flex', activeCount > 0);
    }
  }

  // static controls
  document.querySelectorAll('[data-budget-input]').forEach((input) => {
    input.value = String(state.maxBudget);
    input.addEventListener('input', (e) => {
      state.maxBudget = parseInt(e.target.value, 10);
      render();
    });
  });

  document.querySelectorAll('[data-clear-filters]').forEach((btn) =>
    btn.addEventListener('click', () => {
      state.dest = [];
      state.exp = [];
      state.maxBudget = catalogMaxPrice;
      state.dur = 'Any';
      document.querySelectorAll('[data-budget-input]').forEach((input) => (input.value = String(catalogMaxPrice)));
      render();
    })
  );

  document.querySelector('[data-cycle-sort]')?.addEventListener('click', () => {
    state.sort = (state.sort + 1) % sortOptions.length;
    render();
  });

  const sheet = document.querySelector('[data-filter-panel]');
  const scrim = document.querySelector('[data-sheet-scrim]');
  function openSheet() {
    sheet?.classList.remove('translate-y-full');
    scrim?.classList.remove('opacity-0', 'pointer-events-none');
    document.body.style.overflow = 'hidden';
  }
  function closeSheet() {
    sheet?.classList.add('translate-y-full');
    scrim?.classList.add('opacity-0', 'pointer-events-none');
    document.body.style.overflow = '';
  }
  document.querySelector('[data-open-sheet]')?.addEventListener('click', openSheet);
  document.querySelector('[data-close-sheet]')?.addEventListener('click', closeSheet);
  scrim?.addEventListener('click', closeSheet);

  render();
  // Re-render prices + budget labels when the visitor switches display currency.
  window.addEventListener('sf-currency-changed', render);
</script>
